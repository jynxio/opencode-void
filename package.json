{
  "name": "@jynxio/opencode-plugin",
  "version": "0.1.0",
  "description": "Jynxio's OpenCode Plugins",
  "homepage": "https://github.com/jynxio/opencode-plugin",
  "bugs": {
    "url": "https://github.com/jynxio/opencode-plugin/issues"
  },
  "license": "MIT",
  "author": "Jynxio <me@jynxio.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jynxio/opencode-plugin.git"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "exports": {
    ".": "./dist/index.mjs",
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "vp pack",
    "dev": "vp pack --watch",
    "test": "vp test",
    "check": "vp check",
    "prepublishOnly": "vp run build",
    "ship": "node ./scripts/index.ts"
  },
  "devDependencies": {
    "@types/fs-extra": "11.0.4",
    "@types/node": "25.5.0",
    "@typescript/native-preview": "7.0.0-dev.20260330.1",
    "bumpp": "11.0.1",
    "fs-extra": "11.3.4",
    "type-fest": "5.5.0",
    "typescript": "6.0.2",
    "vite-plus": "0.1.14"
  },
  "packageManager": "pnpm@10.33.0",
  "pnpm": {
    "overrides": {
      "vite": "npm:@voidzero-dev/vite-plus-core@latest",
      "vitest": "npm:@voidzero-dev/vite-plus-test@latest"
    }
  },
  "dependencies": {
    "@opencode-ai/plugin": "1.3.7",
    "@opencode-ai/sdk": "1.3.7",
    "nanoid": "5.1.7"
  }
}